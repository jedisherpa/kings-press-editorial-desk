# King's Press Editorial Desk — local development environment.
# Server-only values. Never prefix secrets with NEXT_PUBLIC_.

# --- Local-first runtime defaults ---
# Tauri sets these automatically in packaged desktop builds. Keep them here for
# browser-based local development with `npm run dev` or `npm run desktop:dev`.
KINGS_PRESS_LOCAL_FIRST=true
DATA_BACKEND=sqlite
STORAGE_PROVIDER=local
KINGS_PRESS_STORAGE=local
KINGS_PRESS_DATA_DIR=.local-data

# --- LLM: editorial gates, revision, platform generators, weave ---
# Local-first default: Ollama native chat. The desktop app also reads the saved
# first-run model choice from KINGS_PRESS_LLM_SETTINGS_PATH.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=
LLM_MAX_TOKENS=32000

# Optional per-task overrides. The desktop app normally stores this in its local
# settings UI as provider profiles + task defaults. Use env vars only when you
# want a project-wide override for browser/dev runs.
# Supported tasks: GATHER, WEAVE, DRAFT, REVIEW, REVISION, OUTPUTS, UTILITY,
# MEDIA_PROMPT, FILE.
# Example: Gather/Weave local, draft with ChatGPT, review with Grok, revise with
# Anthropic.
# LLM_TASK_GATHER_PROVIDER=ollama
# LLM_TASK_GATHER_MODEL=llama3.2
# LLM_TASK_WEAVE_PROVIDER=ollama
# LLM_TASK_WEAVE_MODEL=llama3.2
# LLM_TASK_DRAFT_PROVIDER=openai
# LLM_TASK_DRAFT_MODEL=gpt-4o-mini
# LLM_TASK_DRAFT_API_KEY=
# LLM_TASK_REVIEW_PROVIDER=xai
# LLM_TASK_REVIEW_MODEL=grok-4.3
# LLM_TASK_REVIEW_API_KEY=
# LLM_TASK_REVISION_PROVIDER=anthropic
# LLM_TASK_REVISION_MODEL=claude-haiku-4-5
# LLM_TASK_REVISION_API_KEY=

# Optional cloud key fallbacks. Use only when you opt into the matching provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Multimodal file extraction fallback (PDF/image uploads). Text and .docx are
# extracted locally. Leave blank for fully local text-only development, or use
# Anthropic/Gemini as the hosted PDF/image fallback.
LLM_FILE_PROVIDER=
LLM_FILE_MODEL=
LLM_FILE_BASE_URL=
LLM_FILE_API_KEY=

# --- Media: optional hosted integrations ---
HEDRA_API_KEY=
ELEVENLABS_API_KEY=
MEDIA_OPENAI_API_KEY=
MEDIA_OPENAI_BASE_URL=https://api.openai.com/v1
MEDIA_OPENAI_IMAGE_MODELS=gpt-image-1
MEDIA_OPENAI_AUDIO_MODELS=gpt-4o-mini-tts,tts-1
MEDIA_XAI_API_KEY=
MEDIA_XAI_BASE_URL=https://api.x.ai/v1
MEDIA_XAI_IMAGE_MODELS=grok-2-image
MEDIA_IMAGE_BASE_URL=
MEDIA_IMAGE_API_KEY=
MEDIA_IMAGE_MODELS=

# --- Optional hosted compatibility ---
# The desktop/local-first app does not need Postgres or Supabase. These are kept
# only for the hosted web stack while that compatibility remains in the repo.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Google Drive export ---
# Local-first mode saves exports into app-data storage. Configure these only for
# hosted Google Drive OAuth testing.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/drive/auth/callback

# --- Gather research connectors, all optional/server-only ---
BRAVE_SEARCH_API_KEY=
Brave_Kings_Press=
X_BEARER_TOKEN=
YOUTUBE_API_KEY=
GATHER_CONTACT_EMAIL=
NCBI_API_KEY=

# --- Hosted/dev auth compatibility ---
# Local-first mode resolves a single embedded owner/workspace automatically.
AUTH_DISABLED=true
DEFAULT_USER_ID=dev-user
